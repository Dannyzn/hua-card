# ---------- 任选其一（或设 AI_PROVIDER 强制指定）----------
# 未配置任何 Key 时使用内置示例文案（仍计每日次数）

# OpenAI（默认端点；也可用兼容网关填 OPENAI_BASE_URL）
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek（OpenAI 兼容接口，官方默认如下）
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-xlyIDg0FpNlX7OFehIofDto0mEDtgDAt7q3fb452Vai36Piv
# ANTHROPIC_MODEL=claude-sonnet-4-5-haiku-latest
# 其它示例：claude-sonnet-4-20250514、claude-3-5-sonnet-20241022

# 显式指定用哪一路（openai | deepseek | anthropic；也可写 claude 等同 anthropic）
# AI_PROVIDER=deepseek
